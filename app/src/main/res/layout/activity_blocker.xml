<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingHorizontal="28dp"
    android:paddingTop="60dp"
    android:paddingBottom="48dp">

    <!-- Top label -->
    <TextView
        android:id="@+id/tvTopLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACCESS DENIED"
        android:textSize="11sp"
        android:letterSpacing="0.3"
        android:textColor="@color/accent_primary"
        android:background="@drawable/bg_phase_pill"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Main headline -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Earn Your\nReels."
        android:textSize="56sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-condensed"
        android:includeFontPadding="false"
        android:lineSpacingMultiplier="0.9"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTopLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Sub copy -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No credits left. Do push-ups to unlock your next reel."
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Credits card -->
    <FrameLayout
        android:id="@+id/frameCreditsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_card"
        android:padding="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvCreditsLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="96sp"
                android:textStyle="bold"
                android:textColor="@color/accent_primary"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REEL CREDITS REMAINING"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Do push-ups CTA -->
    <Button
        android:id="@+id/btnDoWorkout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="DO PUSH-UPS TO UNLOCK"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:background="@drawable/bg_button_primary"
        android:textColor="@color/white"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnGoBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp" />

    <!-- Go back ghost button -->
    <Button
        android:id="@+id/btnGoBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="GO BACK"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_button_ghost"
        android:textColor="@color/text_secondary"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
