<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/bg_dark"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="18sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/white"
            android:padding="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎵 Workout Music"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnImport"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Import"
            android:textSize="12sp"
            android:backgroundTint="@color/card_bg"
            android:textColor="@color/accent_orange"
            app:cornerRadius="18dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnNewPlaylist"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="20sp"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/bg_dark"
            app:cornerRadius="18dp"
            android:padding="0dp" />

    </LinearLayout>

    <!-- Stats bar -->
    <TextView
        android:id="@+id/tvTotalStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 songs across 0 playlists"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Import progress -->
    <LinearLayout
        android:id="@+id/importContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTotalStats">

        <ProgressBar
            android:id="@+id/progressImport"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvImportStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/accent_orange"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Playlist RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlaylists"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/importContainer"
        app:layout_constraintBottom_toTopOf="@id/nowPlayingBar" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/importContainer"
        app:layout_constraintBottom_toTopOf="@id/nowPlayingBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎧"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No playlists yet"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to create one, or Import\nfrom YouTube or Spotify"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Now Playing Bar (sticky bottom) -->
    <LinearLayout
        android:id="@+id/nowPlayingBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Seek bar -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressTint="@color/accent_orange"
            android:thumbTint="@color/accent_orange"
            android:progressBackgroundTint="@color/divider"
            android:padding="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <!-- Album art -->
            <ImageView
                android:id="@+id/ivNowPlayingArt"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@color/divider"
                android:scaleType="centerCrop" />

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvNowPlayingTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No song playing"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvNowPlayingArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Controls -->
            <Button
                android:id="@+id/btnPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⏮"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:textColor="@color/white"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnPlayPause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textSize="18sp"
                android:backgroundTint="@color/accent_orange"
                android:textColor="@color/bg_dark"
                app:cornerRadius="24dp"
                android:padding="0dp"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⏭"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:textColor="@color/white"
                android:padding="0dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
