<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Top gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_top_overlay" />

    <!-- Bottom gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_overlay" />

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_stat_item"
            android:stateListAnimator="@null"
            android:padding="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PUSH-UP MODE"
            android:textSize="13sp"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:fontFamily="sans-serif-condensed" />

        <!-- Phase pill -->
        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● SCANNING"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textColor="@color/accent_primary"
            android:background="@drawable/bg_phase_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp" />

    </LinearLayout>

    <!-- BOTTOM HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- Form feedback text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Position yourself for push-ups"
            android:textSize="14sp"
            android:textColor="#BBFFFFFF"
            android:textAlignment="center"
            android:layout_marginBottom="20dp" />

        <!-- Counter cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Reps card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvSessionReps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PUSH-UPS"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Credits card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_gold"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tvSessionCredits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREDITS EARNED"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Total credits bank -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:padding="12dp"
            android:background="@drawable/bg_stat_item">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL BANK  "
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTotalCredits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/accent_primary"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  credits"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- +1 Credit toast -->
    <TextView
        android:id="@+id/tvCreditToast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="+1 🎬  REEL UNLOCKED"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/white"
        android:background="@drawable/bg_toast_coral"
        android:paddingHorizontal="28dp"
        android:paddingVertical="14dp"
        android:visibility="gone" />

</FrameLayout>
