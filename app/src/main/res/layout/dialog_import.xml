<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Source selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Import from:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgSource"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbYouTube"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶  YouTube"
            android:checked="true"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF0000" />

        <RadioButton
            android:id="@+id/rbSpotify"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="♫  Spotify"
            android:textColor="#FFFFFF"
            android:buttonTint="#1DB954" />

    </RadioGroup>

    <!-- URL input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Playlist or Track URL / ID:"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etImportUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste YouTube playlist URL or Spotify playlist URL"
        android:inputType="textUri"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:textSize="13sp"
        android:paddingVertical="12dp" />

    <!-- Target playlist -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add to playlist:"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spinnerPlaylist"
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <!-- Notes -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 YouTube: imports audio-only (~1MB/min)\nSpotify: 30-sec previews or opens Spotify app for full tracks"
        android:textSize="11sp"
        android:textColor="#666666"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="16dp" />

</LinearLayout>
