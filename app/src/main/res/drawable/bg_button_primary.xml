<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow shadow layer -->
    <item
        android:left="6dp"
        android:right="6dp"
        android:top="6dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#60FF2D55" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Button face -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF2D55" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
