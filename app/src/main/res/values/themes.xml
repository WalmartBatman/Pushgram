        <item name="colorPrimaryDark">@color/bg_deep</item>
        <item name="colorAccent">@color/accent_coral</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
